{
  "manifest_version": 3,
  "name": "Browser Use Agent (CDP)",
  "version": "2.0",
  "description": "Agent AI extension using Chrome DevTools Protocol for robust interaction.",
  "permissions": [
    "debugger",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}