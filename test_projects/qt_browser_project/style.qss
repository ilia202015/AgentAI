/* Главное окно */
QMainWindow {
    background-color: #1e1e1e;
}

/* Панель инструментов (Navigation Bar) */
QToolBar {
    background-color: #252526;
    border-bottom: 1px solid #333333;
    padding: 5px;
    spacing: 10px;
}

/* Адресная строка (Omnibox) */
QLineEdit {
    background-color: #3c3c3c;
    border: 1px solid #555555;
    border-radius: 14px;
    padding: 6px 15px;
    color: #e0e0e0;
    font-size: 13px;
    selection-background-color: #007acc;
}

QLineEdit:focus {
    border: 1px solid #007acc;
    background-color: #454545;
}

/* Кнопки на панели (Назад, Вперед, Обновить, Звезда) */
QToolButton {
    background-color: transparent;
    border-radius: 6px;
    padding: 4px;
    icon-size: 20px;
}

QToolButton:hover {
    background-color: #3e3e3e;
}

QToolButton:pressed {
    background-color: #505050;
}

QToolButton:disabled {
    opacity: 0.3;
}

/* Вкладки (QTabWidget и QTabBar) */
QTabWidget::pane {
    border: none;
    background-color: #1e1e1e;
}

QTabBar {
    background-color: #252526;
    qproperty-drawBase: 0;
}

QTabBar::tab {
    background-color: #2d2d2d;
    color: #969696;
    border: 1px solid #333333;
    border-bottom: none;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    padding: 8px 15px;
    min-width: 140px;
    margin-right: 2px;
}

QTabBar::tab:selected {
    background-color: #1e1e1e;
    color: #ffffff;
    border-bottom: 2px solid #007acc;
}

QTabBar::tab:hover:!selected {
    background-color: #383838;
}

/* Индикатор загрузки (Progress Bar) */
QProgressBar {
    border: none;
    background: #252526;
    height: 2px;
}

QProgressBar::chunk {
    background-color: #007acc; /* Синий акцент */
}

/* Статус-бар (если используется) */
QStatusBar {
    background-color: #007acc;
    color: white;
}

/* Контекстные меню */
QMenu {
    background-color: #252526;
    color: #e0e0e0;
    border: 1px solid #454545;
}

QMenu::item:selected {
    background-color: #094771;
}