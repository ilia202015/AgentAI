{
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "python",
        "description": "self_python_prompt",
        "parameters": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "description": "Python код для выполнения, не более 4000 символов, если нужно больше, разбей код на части и сделай несколько запросов"
            }
          },
          "required": [
            "code"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "chat",
        "description": "self_chat_prompt",
        "parameters": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Имя чата"
            },
            "message": {
              "type": "string",
              "description": "Сообщение для отправки в чат"
            }
          },
          "required": [
            "name",
            "message"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "google_search",
        "description": "self_google_search_exec_prompt",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Поисковый запрос"
            },
            "num_results": {
              "type": "integer",
              "description": "Количество результатов (по умолчанию 10)",
              "default": 10
            }
          },
          "required": [
            "query"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "shell",
        "description": "self_shell_prompt",
        "parameters": {
          "type": "object",
          "properties": {
            "command": {
              "type": "STRING",
              "description": "Команда для выполнения (используется только при action=\"run\")."
            },
            "timeout": {
              "type": "INTEGER",
              "description": "Soft timeout в секундах (по умолчанию 5). Максимальное время ожидания ответа перед тем как вернуть управление (процесс продолжит работу в фоне).",
              "default": 5
            },
            "action": {
              "type": "STRING",
              "enum": [
                "run",
                "read",
                "input",
                "interrupt"
              ],
              "description": "Действие с интерактивной оболочкой: run (запуск команды), read (чтение накопившегося вывода), input (отправка текста в stdin), interrupt (прерывание текущего процесса)."
            },
            "input_text": {
              "type": "STRING",
              "description": "Текст для передачи в стандартный ввод (stdin) процесса (используется только при action=\"input\"). Обязательно добавляйте символ переноса строки \\n в конце, если программа ожидает нажатия Enter."
            }
          },
          "required": [
            "action"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "user_profile",
        "description": "self_user_profile_prompt",
        "parameters": {
          "type": "object",
          "properties": {
            "data": {
              "type": "string",
              "description": "Данные для записи в формате json"
            }
          },
          "required": [
            "data"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "http",
        "description": "self_http_prompt",
        "parameters": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "URL-адрес веб-страницы для загрузки и очистки."
            }
          },
          "required": [
            "url"
          ]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "python_str",
        "description": "self_python_str_prompt",
        "parameters": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "description": "Обычный текст для преобразования в Python-строку."
            }
          },
          "required": [
            "text"
          ]
        }
      }
    },
    {
      "function": {
        "name": "sandbox",
        "description": "Prompt 'sandbox' not found.",
        "parameters": {
          "type": "OBJECT",
          "properties": {
            "action": {
              "type": "STRING",
              "enum": [
                "create",
                "start",
                "stop",
                "info",
                "delete"
              ],
              "description": "Действие с песочницей."
            }
          },
          "required": [
            "action"
          ]
        }
      }
    }
  ]
}